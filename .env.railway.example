# Railway 环境变量配置示例
# 复制这些变量到 Railway 项目的 Variables 标签页中

# ===== 后端服务 (backend) =====

# 运行环境
NODE_ENV=production
PORT=3000

# 数据库配置
DATABASE_PATH=/app/data/database.sqlite

# JWT 密钥（生产环境请修改为复杂字符串）
JWT_SECRET=skill-platform-production-secret-key-2026-change-this

# 通义千问 API Key（可选，用于 AI 功能）
QWEN_API_KEY=

# Agent Runtime 地址（部署 Agent Runtime 后填写）
AGENT_RUNTIME_URL=http://agent-runtime:8001


# ===== Agent Runtime 服务 (agent-runtime) =====

# 阿里云 DashScope API Key（必需，用于 Agent 对话）
DASHSCOPE_API_KEY=你的阿里云DashScope API Key

# DashScope API 地址
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 默认使用的模型
DEFAULT_MODEL=qwen-plus

# Agent Runtime 服务配置
AGENT_RUNTIME_PORT=8001
AGENT_RUNTIME_HOST=0.0.0.0

# Agent Runtime 数据库
DATABASE_URL=sqlite+aiosqlite:///./agent_runtime.db


# ===== 前端服务 (Cloudflare Pages) =====

# 后端 API 地址（替换为实际的 Railway 后端 URL）
VITE_API_URL=https://你的后端服务-production.up.railway.app

# Agent Runtime 地址（替换为实际的 Railway Agent Runtime URL）
VITE_AGENT_RUNTIME_URL=https://你的agent-runtime服务-production.up.railway.app
